# Leave blank if you plan to store full sync URLs directly.
VITE_AURA_SYNC_API_BASE=

# Rain push-alerts backend (phase 2). All client-safe / public values.
# Project: aura-weather (Supabase, region us-east-2).
VITE_SUPABASE_URL=https://uyednvctjudnrpheubyv.supabase.co
# Publishable (anon) key — safe to ship in the client; RLS protects the data.
VITE_SUPABASE_ANON_KEY=sb_publishable_hie27UbRx-uz5Qjr1l_oDw_e96OU6tD
# Web Push (VAPID) PUBLIC key. The matching PRIVATE key lives only as an
# Edge Function secret (never in the client). Generated during the alerts build.
VITE_VAPID_PUBLIC_KEY=

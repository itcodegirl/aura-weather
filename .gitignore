# docs/screenshots/*.png are committed: the README embeds them
# directly, so ignoring them rendered broken images on GitHub.
# Regenerate deterministically with `npm run screenshots`.

# scripts/record-trust-contract-demo.mjs may produce intermediate
# artifacts; only the committed demo recording is checked in.
docs/screenshots/*.tmp.webm

